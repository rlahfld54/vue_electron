{
  "name": "vue-electron-bootstrap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:4358 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "db:setup": "powershell -ExecutionPolicy Bypass -File db/setup-local-db.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File db/setup-local-db.ps1 -Reset"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "bootstrap": "^5.3.3",
    "exceljs": "^4.4.0",
    "pg": "^8.21.0",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.1.4",
    "vite": "^6.2.5",
    "wait-on": "^8.0.3"
  }
}
